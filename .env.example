# App settings
APP_TITLE=Omicron Assistant API
API_V1_PREFIX=/v1
SESSION_SECRET_KEY=change-me
SQLITE_DB_PATH=omicron.db

# Gmail OAuth settings
GMAIL_CLIENT_SECRETS_FILE=.creds/gmail_client_secrets.json
GMAIL_SCOPES=
GMAIL_REDIRECT_URI=http://localhost:8000/v1/oauth/gmail/callback
GMAIL_POST_CONNECT_REDIRECT=http://localhost:3000/connected

# OpenAI settings
OPENAI_API_KEY=change-me
MAX_RETRIES=5

# Orchestrator agent settings
ORCHESTRATOR_AGENT_MODEL=gpt-5.2
ORCHESTRATOR_AGENT_REASONING_EFFORT=high
ORCHESTRATOR_AGENT_REASONING_SUMMARY=detailed

# Gmail agent settings
GMAIL_AGENT_MODEL=gpt-5.2
GMAIL_AGENT_REASONING_EFFORT=high
GMAIL_AGENT_REASONING_SUMMARY=detailed

# Google Drive agent settings
GOOGLE_DRIVE_AGENT_MODEL=gpt-5.2
GOOGLE_DRIVE_REASONING_EFFORT=high
GOOGLE_DRIVE_REASONING_SUMMARY=detailed

# Browser agent settings
BROWSER_AGENT_MODEL=gpt-5-mini
BROWSER_AGENT_REASONING_EFFORT=medium
BROWSER_AGENT_REASONING_SUMMARY=detailed
PLAYWRIGHT_MCP_URL=http://localhost:8080/mcp
PLAYWRIGHT_MCP_TIMEOUT=120
PLAYWRIGHT_MCP_SSE_READ_TIMEOUT=600
PLAYWRIGHT_MCP_CLIENT_SESSION_TIMEOUT_SECONDS=120
PLAYWRIGHT_MCP_MAX_RETRY_ATTEMPTS=2
BROWSER_RUNNER_VAULT_SECRET_PREFIX=browser_secrets_

# WhatsApp agent settings
WHATSAPP_AGENT_MODEL=gpt-5.2
WHATSAPP_AGENT_REASONING_EFFORT=medium
WHATSAPP_AGENT_REASONING_SUMMARY=detailed
WHATSAPP_MCP_URL=http://127.0.0.1:8000/mcp
WHATSAPP_MCP_TIMEOUT=120
WHATSAPP_MCP_SSE_READ_TIMEOUT=600
WHATSAPP_MCP_CLIENT_SESSION_TIMEOUT_SECONDS=120
WHATSAPP_MCP_MAX_RETRY_ATTEMPTS=2
WHATSAPP_MCP_CONNECT_ON_STARTUP=true
WHATSAPP_MCP_JWT_AUDIENCE=whatsapp-mcp
WHATSAPP_MCP_JWT_SUBJECT=omicron-api
WHATSAPP_MCP_JWT_SCOPES=whatsapp:mcp whatsapp:send whatsapp:download

# WhatsApp session/runtime settings (per-user runtime abstraction)
WHATSAPP_SESSION_PROVIDER=local
WHATSAPP_BRIDGE_BASE_URL=http://127.0.0.1:8080
WHATSAPP_BRIDGE_JWT_SECRET=change-me
WHATSAPP_BRIDGE_JWT_AUDIENCE=whatsapp-bridge
WHATSAPP_BRIDGE_JWT_ISSUER=omicron-api
WHATSAPP_BRIDGE_JWT_TTL_SECONDS=60
WHATSAPP_BRIDGE_TIMEOUT_SECONDS=10
WHATSAPP_SESSION_CONTROLLER_URL=
WHATSAPP_SESSION_CONTROLLER_JWT_SECRET=
WHATSAPP_SESSION_CONTROLLER_JWT_AUDIENCE=whatsapp-session-controller
WHATSAPP_SESSION_CONTROLLER_JWT_ISSUER=omicron-api
WHATSAPP_SESSION_CONTROLLER_JWT_TTL_SECONDS=60
WHATSAPP_SESSION_CONTROLLER_TIMEOUT_SECONDS=10

# WhatsApp session controller service (runtime control-plane)
WHATSAPP_SESSION_CONTROLLER_APP_TITLE=Omicron WhatsApp Session Controller
WHATSAPP_SESSION_CONTROLLER_API_V1_PREFIX=/v1
WHATSAPP_SESSION_CONTROLLER_HOST=0.0.0.0
WHATSAPP_SESSION_CONTROLLER_PORT=8101
WHATSAPP_SESSION_CONTROLLER_RELOAD=false
WHATSAPP_RUNTIME_ORCHESTRATOR=ecs
WHATSAPP_RUNTIME_SLIDING_TTL_SECONDS=600
WHATSAPP_RUNTIME_MAX_LIFETIME_SECONDS=5400
WHATSAPP_RUNTIME_ENDPOINT_SCHEME=http
WHATSAPP_RUNTIME_ENDPOINT_HOST_TEMPLATE=
WHATSAPP_RUNTIME_BRIDGE_PORT=8080
WHATSAPP_RUNTIME_MCP_PORT=8000
WHATSAPP_RUNTIME_MCP_PATH=/mcp
WHATSAPP_RUNTIME_BRIDGE_BASE_URL_TEMPLATE=
WHATSAPP_RUNTIME_MCP_URL_TEMPLATE=
WHATSAPP_RUNTIME_HEALTH_PROBE_ENABLED=true
WHATSAPP_RUNTIME_HEALTH_PROBE_TIMEOUT_SECONDS=2
WHATSAPP_RUNTIME_BRIDGE_HEALTH_PATH=/health
WHATSAPP_RUNTIME_MCP_HEALTH_PATH=/health
WHATSAPP_CONTROLLER_RUNTIME_LEASE_TABLE=controller_whatsapp_runtime_leases
WHATSAPP_CONTROLLER_AWS_REGION=
WHATSAPP_CONTROLLER_ECS_CLUSTER=
WHATSAPP_CONTROLLER_ECS_TASK_DEFINITION=
WHATSAPP_CONTROLLER_ECS_CAPACITY_PROVIDER=
WHATSAPP_CONTROLLER_ECS_SUBNETS=
WHATSAPP_CONTROLLER_ECS_SECURITY_GROUPS=
WHATSAPP_CONTROLLER_ECS_ASSIGN_PUBLIC_IP=false
WHATSAPP_CONTROLLER_ECS_LAUNCH_TYPE=EC2
WHATSAPP_CONTROLLER_ECS_STARTED_BY_PREFIX=wa-runtime-
